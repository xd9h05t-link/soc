<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>xd9h05t | Terminal</title>
    <style>
        /* Efek Terminal Linux */
        body { 
            background-color: #0a0a0a; 
            color: #00ff41; 
            font-family: 'Courier New', Courier, monospace; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            margin: 0;
            overflow: hidden;
        }

        .terminal-box {
            text-align: center;
            border: 1px solid #00ff41;
            padding: 40px;
            background: rgba(0, 255, 65, 0.05);
            box-shadow: 0 0 15px rgba(0, 255, 65, 0.2);
        }

        img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            filter: grayscale(100%) contrast(120%);
            border: 2px solid #00ff41;
            margin-bottom: 20px;
        }

        .glitch {
            font-size: 24px;
            font-weight: bold;
            text-transform: uppercase;
            position: relative;
            display: inline-block;
        }

        /* Tombol Link */
        .btn {
            display: block;
            margin-top: 30px;
            padding: 15px 25px;
            border: 1px solid #00ff41;
            color: #00ff41;
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: 0.3s;
            position: relative;
        }

        .btn:hover {
            background: #00ff41;
            color: #0a0a0a;
            box-shadow: 0 0 20px #00ff41;
        }

        .cursor {
            display: inline-block;
            width: 10px;
            height: 20px;
            background: #00ff41;
            animation: blink 0.8s infinite;
            vertical-align: middle;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }
    </style>
</head>
<body>

<div class="terminal-box">
    <img src="https://github.com/xd9h05t-link.png" alt="Root">
    <div class="glitch">root@xd9h05t:~#</div>
    <p>Sistem Siap. Akses Terdeteksi.</p>
    
    <a href="https://instagram.com/xd9h05t" target="_blank" class="btn">
        > BUKA_INSTAGRAM
    </a>
    
    <p style="font-size: 12px; margin-top: 30px; color: #008f11;">
        Status: Online <span class="cursor"></span>
    </p>
</div>

</body>
</html>
